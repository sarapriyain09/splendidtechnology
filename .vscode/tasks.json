{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Accounting: Backend Dev Server",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "uvicorn",
        "app.main:app",
        "--reload",
        "--port",
        "8010"
      ],
      "options": {
        "cwd": "${workspaceFolder}/apps/workspace/modules/accounting/backend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Accounting: Backend Tests",
