{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@velynxia/ui/*": ["./packages/ui/*"],
      "@velynxia/auth/*": ["./packages/auth/*"],
      "@velynxia/database/*": ["./packages/database/*"],
      "@velynxia/api-client/*": ["./packages/api-client/*"],
      "@velynxia/shared/*": ["./packages/shared/*"],
      "@velynxia/ai-core/*": ["./packages/ai-core/*"],
      "@velynxia/engineering-core/*": ["./packages/engineering-core/*"],
      "@velynxia/commerce-core/*": ["./packages/commerce-core/*"],
      "@velynxia/media-core/*": ["./packages/media-core/*"],
      "@velynxia/growth-core/*": ["./packages/growth-core/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
