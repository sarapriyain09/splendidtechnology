// Splendid Growth Platform — single Prisma schema, single PostgreSQL database.
//
// Architecture:
//   - common  : platform-owned shared entities (companies, contacts, activities,
//               tasks, notes, documents, users, tags, attachments).
//   - sales / callcrm / marketing / automation / analytics : app-specific models
//               that REFERENCE the shared entities via foreign keys.
//
// Rule: Company and Contact records are never duplicated. Apps relate to them.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================
// ENUMS
// =========================================================

enum UserRole {
  ADMIN
  MANAGER
  AGENT
  USER
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  TASK
  OTHER
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
}

enum OpportunityStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  FULFILLED
  CANCELLED
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallOutcome {
  ANSWERED
  MISSED
  VOICEMAIL
  ABANDONED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
}

enum CampaignChannel {
  EMAIL
  SMS
  SOCIAL
  WEB
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum FeatureKey {
  CRM
  SALES
  CALLCRM
  MARKETING
  AUTOMATION
  ANALYTICS
}

// =========================================================
// COMMON / PLATFORM ENTITIES (owned by the platform)
// =========================================================

model User {
  id           String    @id @default(cuid())
  name         String?
  username     String?   @unique
  email        String    @unique
  passwordHash String?
  role         UserRole  @default(USER)
  phoneNumber  String?   @unique
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  ownedCompanies Company[]  @relation("CompanyOwner")
  ownedContacts  Contact[]  @relation("ContactOwner")
  activities     Activity[]
  assignedTasks  Task[]     @relation("TaskAssignee")
  notes          Note[]
  documents      Document[]
  licenses       UserLicense[]

  @@map("users")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  website     String?
  industry    String?
  phone       String?
  email       String?
  addressLine String?
  city        String?
  postcode    String?
  country     String?
  ownerId     String?
  owner       User?    @relation("CompanyOwner", fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contacts    Contact[]
  activities  Activity[]
  tasks       Task[]
  notes       Note[]
  documents   Document[]
  attachments Attachment[]
  tags        Tag[]        @relation("CompanyTags")

  leads         Lead[]
  opportunities Opportunity[]
  quotes        Quote[]
  orders        Order[]

  @@index([ownerId])
  @@map("companies")
}

model Contact {
  id        String   @id @default(cuid())
  firstName String?
  lastName  String?
  name      String?
  email     String?
  phone     String?
  jobTitle  String?
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  ownerId   String?
  owner     User?    @relation("ContactOwner", fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities  Activity[]
  tasks       Task[]
  notes       Note[]
  documents   Document[]
  attachments Attachment[]
  tags        Tag[]        @relation("ContactTags")

  leads         Lead[]
  opportunities Opportunity[]
  quotes        Quote[]
  orders        Order[]
  callLogs      CallLog[]

  @@index([companyId])
  @@index([ownerId])
  @@map("contacts")
}

model Activity {
  id         String       @id @default(cuid())
  type       ActivityType @default(NOTE)
  subject    String
  body       String?
  occurredAt DateTime     @default(now())
  companyId  String?
  company    Company?     @relation(fields: [companyId], references: [id])
  contactId  String?
  contact    Contact?     @relation(fields: [contactId], references: [id])
  userId     String?
  user       User?        @relation(fields: [userId], references: [id])
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([companyId])
  @@index([contactId])
  @@map("activities")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(OPEN)
  priority    TaskPriority @default(MEDIUM)
  dueAt       DateTime?
  companyId   String?
  company     Company?     @relation(fields: [companyId], references: [id])
  contactId   String?
  contact     Contact?     @relation(fields: [contactId], references: [id])
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([companyId])
  @@index([contactId])
  @@index([assigneeId])
  @@map("tasks")
}

model Note {
  id        String   @id @default(cuid())
  body      String
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([contactId])
  @@map("notes")
}

model Document {
  id        String   @id @default(cuid())
  name      String
  url       String
  mimeType  String?
  sizeBytes Int?
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  ownerId   String?
  owner     User?    @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments Attachment[]

  @@index([companyId])
  @@index([contactId])
  @@map("documents")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String?
  createdAt DateTime @default(now())

  companies Company[] @relation("CompanyTags")
  contacts  Contact[] @relation("ContactTags")

  @@map("tags")
}

model Attachment {
  id         String    @id @default(cuid())
  fileName   String
  url        String
  mimeType   String?
  sizeBytes  Int?
  documentId String?
  document   Document? @relation(fields: [documentId], references: [id])
  companyId  String?
  company    Company?  @relation(fields: [companyId], references: [id])
  contactId  String?
  contact    Contact?  @relation(fields: [contactId], references: [id])
  createdAt  DateTime  @default(now())

  @@index([documentId])
  @@map("attachments")
}

// =========================================================
// SALES APP
// =========================================================

model Lead {
  id             String     @id @default(cuid())
  title          String
  status         LeadStatus @default(NEW)
  source         String?
  estimatedValue Decimal?   @db.Decimal(12, 2)
  companyId      String?
  company        Company?   @relation(fields: [companyId], references: [id])
  contactId      String?
  contact        Contact?   @relation(fields: [contactId], references: [id])
  ownerId        String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  opportunity Opportunity?

  @@index([companyId])
  @@index([contactId])
  @@map("sales_leads")
}

model Pipeline {
  id        String   @id @default(cuid())
  name      String
  isDefault Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stages        PipelineStage[]
  opportunities Opportunity[]

  @@map("sales_pipelines")
}

model PipelineStage {
  id                 String   @id @default(cuid())
  pipelineId         String
  pipeline           Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name               String
  sortOrder          Int      @default(0)
  defaultProbability Int      @default(0)
  isClosed           Boolean  @default(false)
  isWon              Boolean  @default(false)
  createdAt          DateTime @default(now())

  opportunities Opportunity[]

  @@index([pipelineId])
  @@map("sales_pipeline_stages")
}

model Opportunity {
  id                String           @id @default(cuid())
  name              String
  stage             OpportunityStage @default(PROSPECTING)
  amount            Decimal?         @db.Decimal(12, 2)
  currency          String           @default("GBP")
  probability       Int?
  expectedCloseDate DateTime?
  companyId         String
  company           Company          @relation(fields: [companyId], references: [id])
  contactId         String?
  contact           Contact?         @relation(fields: [contactId], references: [id])
  leadId            String?          @unique
  lead              Lead?            @relation(fields: [leadId], references: [id])
  pipelineId        String?
  pipeline          Pipeline?        @relation(fields: [pipelineId], references: [id])
  stageId           String?
  pipelineStage     PipelineStage?   @relation(fields: [stageId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  quotes Quote[]
  orders Order[]

  @@index([companyId])
  @@index([contactId])
  @@index([pipelineId])
  @@index([stageId])
  @@map("sales_opportunities")
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  description String?
  unitPrice   Decimal  @db.Decimal(12, 2)
  currency    String   @default("GBP")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quoteItems QuoteItem[]

  @@map("products")
}

model Quote {
  id            String       @id @default(cuid())
  quoteNumber   String       @unique
  status        QuoteStatus  @default(DRAFT)
  companyId     String?
  company       Company?     @relation(fields: [companyId], references: [id])
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  subtotal      Decimal      @default(0) @db.Decimal(12, 2)
  taxAmount     Decimal      @default(0) @db.Decimal(12, 2)
  total         Decimal      @default(0) @db.Decimal(12, 2)
  currency      String       @default("GBP")
  validUntil    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  items QuoteItem[]
  order Order?

  @@index([companyId])
  @@index([contactId])
  @@index([opportunityId])
  @@map("sales_quotes")
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  lineTotal   Decimal  @db.Decimal(12, 2)

  @@index([quoteId])
  @@map("sales_quote_items")
}

model Order {
  id            String       @id @default(cuid())
  orderNumber   String       @unique
  status        OrderStatus  @default(PENDING)
  companyId     String?
  company       Company?     @relation(fields: [companyId], references: [id])
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  quoteId       String?      @unique
  quote         Quote?       @relation(fields: [quoteId], references: [id])
  total         Decimal      @default(0) @db.Decimal(12, 2)
  currency      String       @default("GBP")
  placedAt      DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([companyId])
  @@index([contactId])
  @@index([opportunityId])
  @@map("sales_orders")
}

// =========================================================
// CALLCRM APP
// =========================================================

model CallCampaign {
  id        String         @id @default(cuid())
  name      String
  status    CampaignStatus @default(DRAFT)
  script    String?
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  callLogs CallLog[]

  @@map("call_campaigns")
}

model CallLog {
  id              String           @id @default(cuid())
  direction       CallDirection    @default(INBOUND)
  fromNumber      String
  toNumber        String
  status          String
  durationSeconds Int?
  outcome         CallOutcome?
  contactId       String?
  contact         Contact?         @relation(fields: [contactId], references: [id])
  campaignId      String?
  campaign        CallCampaign?    @relation(fields: [campaignId], references: [id])
  dispositionId   String?
  disposition     CallDisposition? @relation(fields: [dispositionId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  recordings CallRecording[]

  @@index([fromNumber])
  @@index([status])
  @@index([contactId])
  @@map("call_logs")
}

model CallRecording {
  id              String   @id @default(cuid())
  callLogId       String
  callLog         CallLog  @relation(fields: [callLogId], references: [id], onDelete: Cascade)
  url             String
  durationSeconds Int?
  transcript      String?
  createdAt       DateTime @default(now())

  @@index([callLogId])
  @@map("call_recordings")
}

model CallDisposition {
  id       String  @id @default(cuid())
  code     String  @unique
  label    String
  isActive Boolean @default(true)

  callLogs CallLog[]

  @@map("call_dispositions")
}

// =========================================================
// MARKETING APP
// =========================================================

model Campaign {
  id        String          @id @default(cuid())
  name      String
  channel   CampaignChannel @default(EMAIL)
  status    CampaignStatus  @default(DRAFT)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  emailCampaigns EmailCampaign[]
  smsCampaigns   SMSCampaign[]
  segments       Segment[]       @relation("CampaignSegments")

  @@map("marketing_campaigns")
}

model EmailCampaign {
  id          String    @id @default(cuid())
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
  subject     String
  fromEmail   String
  htmlBody    String?
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([campaignId])
  @@map("marketing_email_campaigns")
}

model SMSCampaign {
  id          String    @id @default(cuid())
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
  message     String
  fromNumber  String?
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([campaignId])
  @@map("marketing_sms_campaigns")
}

model Segment {
  id          String   @id @default(cuid())
  name        String
  description String?
  criteria    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns Campaign[] @relation("CampaignSegments")

  @@map("marketing_segments")
}

model Form {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  schema    Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  landingPages LandingPage[]

  @@map("marketing_forms")
}

model LandingPage {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     Json?
  formId      String?
  form        Form?    @relation(fields: [formId], references: [id])
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([formId])
  @@map("marketing_landing_pages")
}

model Newsletter {
  id        String    @id @default(cuid())
  title     String
  content   String?
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("marketing_newsletters")
}

// =========================================================
// AUTOMATION APP
// =========================================================

model Workflow {
  id          String   @id @default(cuid())
  companyId   String?  @map("company_id")
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  triggers   WorkflowTrigger[]
  conditions WorkflowCondition[]
  actions    WorkflowAction[]
  logs       WorkflowLog[]

  @@index([companyId])
  @@map("workflows")
}

model WorkflowTrigger {
  id         String   @id @default(cuid())
  workflowId String   @map("workflow_id")
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  eventName  String   @map("event_name")

  @@index([workflowId])
  @@index([eventName])
  @@map("workflow_triggers")
}

model WorkflowCondition {
  id         String   @id @default(cuid())
  workflowId String   @map("workflow_id")
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  field      String
  operator   String
  value      String

  @@index([workflowId])
  @@map("workflow_conditions")
}

model WorkflowAction {
  id         String   @id @default(cuid())
  workflowId String   @map("workflow_id")
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  actionType String   @map("action_type")
  actionData Json?    @map("action_data")

  @@index([workflowId])
  @@index([actionType])
  @@map("workflow_actions")
}

model WorkflowLog {
  id         String   @id @default(cuid())
  workflowId String   @map("workflow_id")
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status     String
  message    String?
  executedAt DateTime @default(now()) @map("executed_at")

  @@index([workflowId])
  @@index([executedAt])
  @@map("workflow_logs")
}

model PromptHistory {
  id         String   @id @default(cuid())
  prompt     String
  response   String?
  model      String?
  tokensUsed Int?
  createdAt  DateTime @default(now())

  @@map("prompt_history")
}

// =========================================================
// ANALYTICS APP
// =========================================================

model Dashboard {
  id        String   @id @default(cuid())
  companyId String?  @map("company_id")
  name      String
  layout    Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  widgets Widget[]

  @@index([companyId])
  @@map("dashboards")
}

model Widget {
  id          String    @id @default(cuid())
  dashboardId String    @map("dashboard_id")
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  widgetType  String    @map("widget_type")
  config      Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([dashboardId])
  @@index([widgetType])
  @@map("widgets")
}

model Report {
  id        String   @id @default(cuid())
  companyId String?  @map("company_id")
  name      String
  query     Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("reports")
}

// =========================================================
// LICENSING (controls which apps a user can see)
// =========================================================

model License {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  features LicenseFeature[]
  users    UserLicense[]

  @@map("licenses")
}

model LicenseFeature {
  licenseId String
  license   License    @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  feature   FeatureKey

  @@id([licenseId, feature])
  @@map("license_features")
}

model UserLicense {
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseId  String
  license    License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([userId, licenseId])
  @@index([licenseId])
  @@map("user_licenses")
}

