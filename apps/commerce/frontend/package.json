{
  "name": "@velynxia/product-intelligence-frontend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev -p 3020",
    "build": "next build",
    "start": "next start -p 3020",
    "lint": "next lint",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "clean:next": "node -e \"const fs=require('fs');fs.rmSync('.next',{recursive:true,force:true});\"",
    "test:e2e": "npm run clean:next && playwright test",
    "test:e2e:smoke": "npm run clean:next && playwright test tests/e2e/navigation-smoke.spec.ts",
    "test:e2e:headed": "npm run clean:next && playwright test --headed",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "next": "15.3.4",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
